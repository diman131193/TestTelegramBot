          "text": "натуральные, не окрашиваю",
          "next": "2"
        },
        {
          "id": "1.2",
          "text": "окрашенные в 1 тон (без блонда)",
          "next": "2"
        },
        {
          "id": "1.3",
          "text": "окрашены по длине, отращиваю свой цвет (без блонда)",
          "next": "2"
        },
        {
          "id": "1.4",
          "text": "блонд/осветленные по всей длине",
          "next": "2"
        },
